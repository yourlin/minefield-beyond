{
  "name": "minesweeper",
  "version": "0.1.0",
  "description": "高挑战性扫雷游戏 — 多拓扑 × 多信息机制 × 确定性可解",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "build:core": "tsc -p src/core/tsconfig.json",
    "dev:game": "vite src/game",
    "dev:reader": "vite src/reader",
    "build:game": "vite build src/game",
    "build:reader": "vite build src/reader"
  },
  "author": "Linyesh",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "~8.59.1",
    "@typescript-eslint/parser": "~8.59.1",
    "eslint": "~9.39.4",
    "eslint-config-prettier": "~10.1.8",
    "prettier": "~3.8.3",
    "typescript": "~5.9.0",
    "vite": "^8.0.10",
    "vitest": "~4.1.5"
  }
}
